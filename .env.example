# Copy this file to .env and fill in the values

# PostgreSQL connection string
# Local example: postgresql://user:password@localhost:5432/bookstore
# Railway provides this automatically when you add the Postgres plugin
DATABASE_URL=postgresql://user:password@localhost:5432/bookstore

# Secret key for signing JWT tokens — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Server port (Railway sets this automatically)
PORT=3000

# Set to "production" on Railway
NODE_ENV=development

# OmniWare Payment Gateway (https://pgbiz.omniware.in)
# Get these from your OmniWare merchant dashboard
OMNIWARE_API_KEY=your_omniware_api_key
OMNIWARE_SALT=your_omniware_salt
